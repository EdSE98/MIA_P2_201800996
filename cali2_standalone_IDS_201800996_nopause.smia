# Standalone adaptado para carnet 201800996
# Prepara /home/eduardo/mia/cali/d3.dsk para que cali2 pueda ejecutarse sin cali1 previo.
mkdisk -size=100 -path=/home/eduardo/mia/cali/d3.dsk -fit=bf
fdisk -unit=M -name=Part1D3 -size=25 -path=/home/eduardo/mia/cali/d3.dsk -fit=BF -type=E

#MOUNT
mount -path=/home/eduardo/mia/cali/d3.dsk -name=Part1D3

#MKFS A PARTICION
mkfs -type-=full -id-=961A #MKFS a Part1D3 del disco con nombre d3.dsk

#REPORTES INICIALES
rep -id=961A -Path="/home/eduardo/parte2/reportes/iniciales/ext2_sb_1.jpg" -name=sb
rep -Path="/home/eduardo/parte2/reportes/iniciales/ext2_tree_1.jpg" -name=tree -id=961A


#Eerror
Loogin -pass=567 -usr=roca -id=961A

#Error
Login -pass=567 -usr=roca -id=961A
#error
logout
Login -pass=123 -usr=root -id=961A


#CREACION DE GRUPOS
mkgrp -naMe=Archivos
mkgrp -naMe=elAuxEsBuenaOnda
mkgRP -naMe=elAuxEsBuenaOnda
mkgRP -naMe=Arquizzz
mkgRP -naMe=yaNoSale
mkgRP -naMe=eliminar
mkgRP -naMe=eliminiado_s

#Validar cambios en el archivo
Cat -file=/users.txt

#ELIMINACION DE GRUPOS
rmgrp -name=eliminiado_s
rmgrp -nam=eliminir

#Validar cambios en el archivo
Cat -file=/users.txt

#CREACION DE USUARIOS
Mkusr -user="user1" -grp=root -pass=user1
Mkuser -user="user2" -pass=user2 -grp=elAuxEsBuenaOnda 
Mkuser -grp=Arquizzz -user="user3" -pass=user3
Mkuser -user="user4" -grp==yaNoSale -pass=user4
Mkuser -user="eliminar" -grp==Archivos -pass=del

#Validar cambios en el archivo
Cat -file=/users.txt

#ELIMINACION DE USUARIOS
rmusr -usr="eliminar"
rmusr -usr="user3"
rmusrr -usr="user1"

#Validar cambios en el archivo
Cat -file=/users.txt

#CAMBIAR USUARIO DE GRUPO
chgrp -usr="user3" -grp=elAuxEsBuenaOnda
chgrp -usr="user4" -grupo=elAuxEsBuenaOnda

#Validar cambios en el archivo
